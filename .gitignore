.coverage
htmlcov/

# Mypy / Ruff
.mypy_cache/
.ruff_cache/

# Output from tools
output*/
work/
logs/
playlists/

# OS junk
.DS_Store
Thumbs.db

# Cursor
.cursorignore
.cursorindexingignore
