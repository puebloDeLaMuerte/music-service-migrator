# =============================================================================
# music-service-migrator configuration
# Copy to .env and fill in required values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Spotify API credentials
# Get these from https://developer.spotify.com/dashboard
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# -----------------------------------------------------------------------------
# Tidal API credentials (for future use)
# -----------------------------------------------------------------------------
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------------
WORK_DIR=./work
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# TUI (optional — also editable in Settings)
# -----------------------------------------------------------------------------
# TUI_STATUS_FLASH_SECONDS=5
#
# Playlist→Album: skip the loose-tracks dialog after Extract+delete; always keep file
# P2A_ALWAYS_KEEP_LEFTOVERS=1
