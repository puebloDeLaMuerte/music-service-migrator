# =============================================================================
# music-service-migrator configuration
# Copy to .env and fill in required values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Spotify API credentials
# Get these from https://developer.spotify.com/dashboard
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# -----------------------------------------------------------------------------
# Tidal API credentials (for future use)
# -----------------------------------------------------------------------------
# TIDAL_CLIENT_ID=
# TIDAL_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------------
OUTPUT_DIR=./output
LOG_LEVEL=INFO
